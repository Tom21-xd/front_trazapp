# =============================================================================
# front_trazapp - Variables de entorno (PLANTILLA)
# -----------------------------------------------------------------------------
# Copia este archivo a `.env.local` y ajusta los valores.
#   cp .env.example .env.local
# Las variables NEXT_PUBLIC_* se exponen al navegador (no pongas secretos aquí).
# =============================================================================

# URL del backend API (incluye el prefijo /api).
# El backend corre por defecto en el puerto 3000.
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# URL pública de esta app (para metadatos / PWA).
# El frontend corre en el puerto 3001 (ver script "dev": next dev -p 3001).
NEXT_PUBLIC_APP_URL=http://localhost:3001
